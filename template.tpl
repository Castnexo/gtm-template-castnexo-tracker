const setInWindow = require('setInWindow');
const injectScript = require('injectScript');
const makeNumber = require('makeNumber');
const queryPermission = require('queryPermission');

const SCRIPT_URL = 'https://tracker.castnexo.com.br/script/latest.js';

// Só injeta o script se a permissão do template autorizar a URL.
if (queryPermission('inject_script', SCRIPT_URL)) {

  // Workspace ID — obrigatório. Identifica a conta Castnexo de destino.
  setInWindow('__GM_WORKSPACE_ID__', data.workspaceId, true);

  // Decoração de links de checkout — ativada por padrão no script.
  // Só é desligada quando o usuário marca a opção explicitamente.
  if (data.disableCheckoutDecorator) {
    setInWindow('__GM_CHECKOUT_DECORATOR__', 'false', true);

    // Vínculo do checkout quando a decoração está desligada.
    if (data.linkCookie) {
      setInWindow('__GM_LINK_COOKIE__', data.linkCookie, true);
    }
    if (data.checkoutSrcParam) {
      setInWindow('__GM_CHECKOUT_SRC_PARAM__', data.checkoutSrcParam, true);
    }
  }

  // Eventos do dataLayer a capturar.
  if (data.dlEvents) {
    const events = [];
    for (let i = 0; i < data.dlEvents.length; i++) {
      const name = data.dlEvents[i].eventName;
      if (name) {
        events.push(name);
      }
    }
    if (events.length > 0) {
      setInWindow('__GM_DL_EVENTS__', events, true);
    }
  }

  // Domínios para vínculo cross-domain. Aceita entradas com https://, http://,
  // // ou trailing slash/path/query e normaliza para um hostname limpo em lowercase.
  if (data.crossDomain) {
    const domains = [];
    for (let i = 0; i < data.crossDomain.length; i++) {
      let d = data.crossDomain[i].domain;
      if (!d) continue;
      d = d.trim();
      const lower = d.toLowerCase();
      if (lower.indexOf('https://') === 0) {
        d = d.substring(8);
      } else if (lower.indexOf('http://') === 0) {
        d = d.substring(7);
      } else if (d.indexOf('//') === 0) {
        d = d.substring(2);
      }
      const slash = d.indexOf('/');
      if (slash !== -1) d = d.substring(0, slash);
      const qmark = d.indexOf('?');
      if (qmark !== -1) d = d.substring(0, qmark);
      d = d.toLowerCase();
      if (d) domains.push(d);
    }
    if (domains.length > 0) {
      setInWindow('__GM_CROSS_DOMAIN__', domains, true);
    }
  }

  // Demais configurações opcionais.
  if (data.sessionTimeout) {
    setInWindow('__GM_SESSION_TIMEOUT__', makeNumber(data.sessionTimeout), true);
  }

  if (data.utmTtlDays) {
    setInWindow('__GM_UTM_TTL_DAYS__', makeNumber(data.utmTtlDays), true);
  }

  if (data.debug) {
    setInWindow('__GM_TRACKER_DEBUG__', true, true);
  }

  // Injeta o loader do tracker. O loader carrega a versão ativa do script.
  injectScript(SCRIPT_URL, data.gtmOnSuccess, data.gtmOnFailure, 'castnexo-tracker');

} else {
  // Permissão de injeção ausente — sinaliza falha da tag.
  data.gtmOnFailure();
}

